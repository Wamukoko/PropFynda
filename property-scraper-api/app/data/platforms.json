[
  {
    "id": "buyrentkenya",
    "name": "BuyRentKenya",
    "base_url": "https://www.buyrentkenya.com",
    "listing_paths": [
      "/property-for-sale",
      "/property-for-rent"
    ],
    "type": "portal",
    "active": true,
    "adapter": "buyrentkenya",
    "scrape_priority": 1,
    "notes": "Reference implementation. Phone numbers are gated behind a JS reveal - contact_gate uses Playwright to click 'View Number' and extract the revealed phone.",
    "contact_gate": {
      "type": "click_to_reveal",
      "selector": "a[href*='tel:'], .view-number-btn, button:has-text('View Number')",
      "wait_selector": ".phone-number, a[href^='tel:']",
      "use_playwright": true,
      "wait_timeout_ms": 5000
    }
  },
