DATABASE_URL=sqlite:///./data/listings.db
SCRAPE_INTERVAL_MINUTES=180
REQUEST_TIMEOUT_SECONDS=20
MIN_DELAY_BETWEEN_REQUESTS_SECONDS=2.0
MAX_PAGES_PER_PLATFORM_PER_RUN=3
MAX_LISTINGS_PER_PLATFORM_PER_RUN=60
SCRAPER_USER_AGENT=PropertyAggregatorBot/0.1 (+contact: you@yourdomain.com)
RESPECT_ROBOTS_TXT=true

# Contact extraction (your own sites)
CONTACT_EXTRACTION_ENABLED=true
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=30000

# Circuit breaker: auto-disable a platform after N consecutive failures
MAX_CONSECUTIVE_FAILURES=3

# Stale listing threshold in days
STALE_LISTING_DAYS=30

# AI Assistant (Agent Eve)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
